generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String @default("passenger")

  crowdReports CrowdReport[]
  emergencyReports EmergencyReport[]
  notifications Notification[]
  gpsLogs GPSLog[]
  ownedBuses Bus[]
}
model Bus {
  id                  Int      @id @default(autoincrement())

  licensePlate        String   @unique
  routePermitNumber   String?

  busType             String
  category            String

  imageUrl            String?

  // ROUTE
  routeId Int?
  route   Route? @relation(fields: [routeId], references: [id])

  // OWNER
  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id])

  // RELATIONS
  drivers Driver[]
  gpsLogs GPSLog[]
  crowdReports CrowdReport[]
  emergencyReports EmergencyReport[]

  createdAt DateTime @default(now())
}
model Driver {
  id            Int    @id @default(autoincrement())
  name          String
  phoneNumber   String
  licenseNumber String

  busId Int?
  bus   Bus? @relation(fields: [busId], references: [id])
}
model Route {
  id             Int      @id @default(autoincrement())
  routeNumber    String
  startLocation  String
  endLocation    String
  departureTime  String
  arrivalTime    String

  buses Bus[]
  distanceKm Float?

  createdAt DateTime @default(now())
}
model GPSLog {
  id              Int      @id @default(autoincrement())

  latitude        Float
  longitude       Float

  trackingSource  String

  busId Int
  bus   Bus @relation(fields: [busId], references: [id])

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
model CrowdReport {
  id          Int      @id @default(autoincrement())
  crowdLevel  String

  busId Int
  bus   Bus @relation(fields: [busId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
model EmergencyReport {
  id              Int      @id @default(autoincrement())
  emergencyType   String
  description     String?

  latitude        Float?
  longitude       Float?

  userId Int
  user   User @relation(fields: [userId], references: [id])

  busId Int?
  bus   Bus? @relation(fields: [busId], references: [id])

  createdAt DateTime @default(now())
}
model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}