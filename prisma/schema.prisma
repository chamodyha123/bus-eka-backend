generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String @default("passenger")
}
model Bus {
  id                  Int      @id @default(autoincrement())
  licensePlate        String   @unique
  routePermitNumber   String?
  busType             String
  category            String
  imageUrl            String?

  drivers Driver[]

  createdAt DateTime @default(now())
}
model Driver {
  id            Int    @id @default(autoincrement())
  name          String
  phoneNumber   String
  licenseNumber String

  busId Int?
  bus   Bus? @relation(fields: [busId], references: [id])
}